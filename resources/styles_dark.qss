/* === ОСНОВА === */
QWidget {
    background-color: #0f0f0f;
    color: #f5f5f5;
    font-family: "Segoe UI", "SF Pro Display", sans-serif;
    font-size: 10pt;
}

QMainWindow {
    background-color: #0f0f0f;
}

/* === HEADER === */
QFrame#header_bar {
    background-color: #0f0f0f;
    border-bottom: 1px solid #252525;
}

QLabel#app_title {
    font-size: 14pt;
    font-weight: 600;
    color: #f5f5f5;
}

QPushButton#settings_btn {
    background: transparent;
    border: none;
    border-radius: 8px;
}

QPushButton#settings_btn:hover {
    background-color: #252525;
}

/* === КНОПКИ === */
QPushButton {
    background-color: #1a1a1a;
    color: #f5f5f5;
    border: none;
    border-radius: 8px;
    padding: 10px 20px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #252525;
}

QPushButton:pressed {
    background-color: #22c55e;
    color: #0f0f0f;
}

QPushButton:disabled {
    background-color: #1a1a1a;
    color: #525252;
}

QPushButton#process_button {
    background-color: #22c55e;
    color: #0f0f0f;
    font-size: 12pt;
    font-weight: 600;
    padding: 14px;
}

QPushButton#process_button:hover {
    background-color: #16a34a;
}

QPushButton#process_button:pressed {
    background-color: #15803d;
}

QPushButton#process_button:disabled {
    background-color: #1a1a1a;
    color: #525252;
}

QPushButton#ok_button {
    background-color: #22c55e;
    color: #0f0f0f;
    font-weight: 600;
}

QPushButton#ok_button:hover {
    background-color: #16a34a;
}

/* === INPUTS === */
QLineEdit, QSpinBox, QComboBox, QPlainTextEdit {
    background-color: #1a1a1a;
    border: none;
    border-bottom: 2px solid #252525;
    border-radius: 0;
    padding: 10px;
    color: #f5f5f5;
    selection-background-color: #22c55e;
    selection-color: #0f0f0f;
}

QLineEdit:focus, QSpinBox:focus, QComboBox:focus, QPlainTextEdit:focus {
    border-bottom: 2px solid #22c55e;
}

QLineEdit:disabled, QSpinBox:disabled, QComboBox:disabled {
    color: #525252;
}

QComboBox::drop-down {
    border: none;
    background: transparent;
    width: 24px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid #a3a3a3;
    margin-right: 8px;
}

QComboBox QAbstractItemView {
    background-color: #1a1a1a;
    border: 1px solid #252525;
    selection-background-color: #22c55e;
    selection-color: #0f0f0f;
    outline: none;
}

/* === СПИСКИ === */
QListWidget {
    background-color: #1a1a1a;
    border: none;
    border-radius: 12px;
    padding: 8px;
    outline: none;
}

QListWidget::item {
    padding: 12px;
    border-radius: 8px;
    color: #f5f5f5;
}

QListWidget::item:hover {
    background-color: #252525;
}

QListWidget::item:selected {
    background-color: #22c55e;
    color: #0f0f0f;
}

/* === ВКЛАДКИ === */
QTabWidget::pane {
    border: none;
    background-color: transparent;
}

QTabBar {
    qproperty-expanding: false;
}

QTabBar::tab {
    background-color: transparent;
    color: #737373;
    border: none;
    padding: 10px 20px;
    font-weight: 500;
}

QTabBar::tab:hover {
    color: #a3a3a3;
}

QTabBar::tab:selected {
    color: #22c55e;
    border-bottom: 2px solid #22c55e;
}

/* === ГРУППЫ (минимализм - без рамок) === */
QGroupBox {
    background-color: transparent;
    border: none;
    margin-top: 24px;
    padding-top: 8px;
}

QGroupBox::title {
    color: #737373;
    font-size: 9pt;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 0;
    subcontrol-origin: margin;
    subcontrol-position: top left;
}

/* === CHECKBOXES === */
QCheckBox {
    color: #f5f5f5;
    spacing: 10px;
    background: transparent;
}

QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border-radius: 6px;
    border: 2px solid #404040;
    background-color: transparent;
}

QCheckBox::indicator:hover {
    border-color: #525252;
}

QCheckBox::indicator:checked {
    background-color: #22c55e;
    border-color: #22c55e;
}

QCheckBox::indicator:disabled {
    border-color: #2a2a2a;
}

/* === RADIO BUTTONS === */
QRadioButton {
    color: #f5f5f5;
    spacing: 10px;
    background: transparent;
}

QRadioButton::indicator {
    width: 20px;
    height: 20px;
    border-radius: 10px;
    border: 2px solid #404040;
    background-color: transparent;
}

QRadioButton::indicator:hover {
    border-color: #525252;
}

QRadioButton::indicator:checked {
    background-color: #22c55e;
    border: 4px solid #1a1a1a;
}

/* === PROGRESS BAR === */
QProgressBar {
    background-color: #252525;
    border: none;
    border-radius: 4px;
    height: 8px;
    text-align: center;
}

QProgressBar::chunk {
    background-color: #22c55e;
    border-radius: 4px;
}

/* === SCROLLBARS === */
QScrollBar:vertical {
    background-color: transparent;
    width: 8px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background-color: #404040;
    border-radius: 4px;
    min-height: 40px;
}

QScrollBar::handle:vertical:hover {
    background-color: #525252;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
    background: none;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar:horizontal {
    background-color: transparent;
    height: 8px;
    margin: 0;
}

QScrollBar::handle:horizontal {
    background-color: #404040;
    border-radius: 4px;
    min-width: 40px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #525252;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
    background: none;
}

QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: none;
}

/* === LABELS === */
QLabel {
    color: #f5f5f5;
    background: transparent;
}

QLabel#status_label {
    color: #737373;
}

QLabel#dnd_label {
    color: #525252;
    font-style: italic;
}

QLabel#previewLabel {
    border: 1px solid #252525;
    background-color: #1a1a1a;
    border-radius: 8px;
}

/* === SLIDERS === */
QSlider::groove:horizontal {
    background-color: #252525;
    height: 4px;
    border-radius: 2px;
}

QSlider::handle:horizontal {
    background-color: #22c55e;
    width: 16px;
    height: 16px;
    margin: -6px 0;
    border-radius: 8px;
}

QSlider::handle:horizontal:hover {
    background-color: #16a34a;
}

QSlider::handle:horizontal:disabled {
    background-color: #404040;
}

/* === SPLITTER === */
QSplitter::handle {
    background-color: #252525;
}

QSplitter::handle:hover {
    background-color: #22c55e;
}

/* === DIALOGS === */
QDialog {
    background-color: #1a1a1a;
}

QDialog#settings_dialog {
    background-color: #1a1a1a;
}

/* === MENUS === */
QMenu {
    background-color: #1a1a1a;
    border: 1px solid #252525;
    border-radius: 8px;
    padding: 4px;
}

QMenu::item {
    padding: 10px 24px;
    border-radius: 6px;
    color: #f5f5f5;
}

QMenu::item:selected {
    background-color: #22c55e;
    color: #0f0f0f;
}

/* === MESSAGE BOX === */
QMessageBox {
    background-color: #1a1a1a;
}

QMessageBox QLabel {
    color: #f5f5f5;
}

/* === TOOLTIPS === */
QToolTip {
    background-color: #1a1a1a;
    color: #f5f5f5;
    border: 1px solid #252525;
    border-radius: 6px;
    padding: 8px;
}

/* === LINKS === */
QLabel[text*="<a"] {
    color: #f5f5f5;
}
